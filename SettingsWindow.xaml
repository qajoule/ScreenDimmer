<Window x:Class="ScreenDimmer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="300" SizeToContent="Height" Topmost="True" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Opacity (0:Clear - 255:Dark)" Margin="0,0,0,10"/>
        <Slider Name="AlphaSlider" Minimum="0" Maximum="255" ValueChanged="AlphaSlider_ValueChanged" />
        <Button Content="Close" Click="Close_Click" Margin="0,15,0,0" Width="100"/>
    </StackPanel>
</Window>